  "query": "SELECT sc.id, sc.stage_id, sc.context_key, sc.context_id, sc.rollout_percentage, sc.serve, sc.priority,\n                      c.team_id, c.key\n               FROM feature_stage_criteria sc\n               JOIN contexts c ON c.id = sc.context_id\n               WHERE sc.stage_id = $1\n               ORDER BY sc.priority ASC, sc.id",
