# Ignore build output and dependencies
# Ignore build output and dependencies
**/target/
!target/.gitkeep

# Don't ignore .sqlx directory (needed for offline sqlx compilation)
!.sqlx/

# Ignore environment files
feature-toggle-backend/.env
.env
.env.local

# Ignore IDE/editor config
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Ignore logs and temp files
*.log
*.tmp
logs/
feature-toggle-backend/logs/
feature-edge-server/logs/

# Ignore test output
/coverage

# Ignore node_modules if present
node_modules/

# Ignore version control
.git
.gitignore

# Ignore database files
*.sqlite
*.db

# Ignore backup files
*.bak
*.old
*.orig

# Documentation (not needed in containers)
docs/
README.md
DOCKER.md

# Don't ignore individual Dockerfiles since we need them for context
# But ignore the main one as it's being replaced
Dockerfile
docker-compose.yml
.dockerignore
