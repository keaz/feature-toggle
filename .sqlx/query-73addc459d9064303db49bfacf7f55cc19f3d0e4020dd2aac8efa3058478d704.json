{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, user_id, token_hash, expires_at, created_at, revoked_at, is_revoked\n            FROM jwt_tokens \n            WHERE user_id = $1 \n            AND is_revoked = FALSE \n            AND expires_at > CURRENT_TIMESTAMP\n            ORDER BY created_at DESC\n            ",
